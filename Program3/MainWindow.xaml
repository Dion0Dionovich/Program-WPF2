<Window x:Class="Program3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="Личный кабинет франчайзера" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <!-- Стиль элемента бокового меню -->
        <Style x:Key="MenuListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#b8c7ce"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e282c"/>
                    <Setter Property="BorderBrush" Value="#3c8dbc"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для вложенных пунктов меню -->
        <Style x:Key="SubMenuItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="30,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#b8c7ce"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e282c"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Конвертер видимости в логическое значение (для стрелок) -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#d2d6de" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <!-- Логотип и кнопка сворачивания меню (перенесена сюда для удобства) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ToggleSidebarButton" Style="{StaticResource MaterialDesignFlatButton}"
                            Width="30" Height="30" Padding="0" Margin="0,0,10,0"
                            ToolTip="Свернуть/развернуть меню">
                        <materialDesign:PackIcon Kind="Menu" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Text="Лого" FontSize="18" FontWeight="Bold" Foreground="#444"/>
                </StackPanel>

                <!-- Правая часть: язык и профиль -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="🇷🇺" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>

                    <!-- Выпадающий профиль (Dropdown) -->
                    <Border Background="#f4f4f4" CornerRadius="4" Padding="5,3" Cursor="Hand"
                            x:Name="ProfileDropdownButton">
                        <StackPanel Orientation="Horizontal">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Аватар (заглушка) -->
                                <Ellipse Width="32" Height="32" Fill="#d2d6de" Margin="0,0,8,0"/>
                                <TextBlock Text="👤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Автоматов А. А." FontWeight="SemiBold" Foreground="#333"/>
                                    <TextBlock Text="Франчайзер" FontSize="11" Foreground="#777"/>
                                </StackPanel>
                            </Grid>
                            <materialDesign:PackIcon Kind="ChevronDown" Width="16" Height="16" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Popup для выпадающего меню (реализуется в коде) -->
                        <Border.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="Профиль" Margin="5"/>
                                    <TextBlock Text="Настройки" Margin="5"/>
                                    <Separator/>
                                    <TextBlock Text="Выход" Margin="5"/>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНАЯ ОБЛАСТЬ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" x:Name="SidebarColumn"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- БОКОВОЕ МЕНЮ -->
            <Border Grid.Column="0" Background="#222d32" x:Name="SidebarBorder">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <!-- Заголовок "НАВИГАЦИЯ" -->
                        <Border Height="45" Background="#1a2226">
                            <TextBlock Text="НАВИГАЦИЯ" VerticalAlignment="Center" Margin="15,0" 
                                       Foreground="#4b646f" FontSize="11" FontWeight="Bold"/>
                        </Border>

                        <!-- Меню в виде ListBox -->
                        <ListBox Background="Transparent" BorderThickness="0" 
                                 ItemContainerStyle="{StaticResource MenuListItemStyle}"
                                 x:Name="MainMenuListBox">
                            <!-- Главная -->
                            <ListBoxItem IsSelected="True">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="18" Height="18"/>
                                    <TextBlock Text="Главная" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Монитор ТА (раскрывающийся) -->
                            <ListBoxItem x:Name="MonitorMenuItem">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Monitor" Width="18" Height="18"/>
                                            <TextBlock Text="Монитор ТА" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <!-- Индикатор раскрытия (стрелка) -->
                                        <materialDesign:PackIcon Grid.Column="1" Kind="ChevronRight" 
                                                                 Width="14" Height="14" VerticalAlignment="Center"
                                                                 x:Name="MonitorArrow"/>
                                    </Grid>
                                    <!-- Вложенные пункты -->
                                    <ListBox Margin="20,5,0,0" Background="Transparent" BorderThickness="0"
                                             ItemContainerStyle="{StaticResource SubMenuItemStyle}" 
                                             x:Name="MonitorSubMenu">
                                        <ListBoxItem>📊 Дашборд</ListBoxItem>
                                        <ListBoxItem>🗺️ Карта</ListBoxItem>
                                        <ListBoxItem>📈 Статистика</ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Детальные отчеты -->
                            <ListBoxItem x:Name="ReportsMenuItem">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ChartBar" Width="18" Height="18"/>
                                            <TextBlock Text="Детальные отчеты" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Grid.Column="1" Kind="ChevronRight" 
                                                                 Width="14" Height="14" VerticalAlignment="Center"
                                                                 x:Name="ReportsArrow"/>
                                    </Grid>
                                    <ListBox Margin="20,5,0,0" Background="Transparent" BorderThickness="0"
                                             ItemContainerStyle="{StaticResource SubMenuItemStyle}" 
                                             x:Name="ReportsSubMenu">
                                        <ListBoxItem>📋 По автоматам</ListBoxItem>
                                        <ListBoxItem>💰 По продажам</ListBoxItem>
                                        <ListBoxItem>📦 По инкассации</ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Учет ТМЦ -->
                            <ListBoxItem x:Name="InventoryMenuItem">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="PackageVariant" Width="18" Height="18"/>
                                            <TextBlock Text="Учет ТМЦ" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Grid.Column="1" Kind="ChevronRight" 
                                                                 Width="14" Height="14" VerticalAlignment="Center"
                                                                 x:Name="InventoryArrow"/>
                                    </Grid>
                                    <ListBox Margin="20,5,0,0" Background="Transparent" BorderThickness="0"
                                             ItemContainerStyle="{StaticResource SubMenuItemStyle}" 
                                             x:Name="InventorySubMenu">
                                        <ListBoxItem>📦 Склад</ListBoxItem>
                                        <ListBoxItem>🔄 Перемещения</ListBoxItem>
                                        <ListBoxItem>📊 Остатки</ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Администрирование -->
                            <ListBoxItem x:Name="AdminMenuItem">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Cog" Width="18" Height="18"/>
                                            <TextBlock Text="Администрирование" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Grid.Column="1" Kind="ChevronRight" 
                                                                 Width="14" Height="14" VerticalAlignment="Center"
                                                                 x:Name="AdminArrow"/>
                                    </Grid>
                                    <ListBox Margin="20,5,0,0" Background="Transparent" BorderThickness="0"
                                             ItemContainerStyle="{StaticResource SubMenuItemStyle}" 
                                             x:Name="AdminSubMenu">
                                        <ListBoxItem>🏧 Торговые автоматы</ListBoxItem>
                                        <ListBoxItem>🏢 Компании</ListBoxItem>
                                        <ListBoxItem>👥 Пользователи</ListBoxItem>
                                        <ListBoxItem>📶 Модемы</ListBoxItem>
                                        <ListBoxItem>⚙️ Дополнительные</ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Связь с тех. поддержкой -->
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Headset" Width="18" Height="18"/>
                                    <TextBlock Text="Связь с тех. поддержкой" Margin="10,0,0,0"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ОСНОВНОЙ КОНТЕНТ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#ecf0f5" BorderBrush="#d2d6de" BorderThickness="0,0,0,1">
                    <Grid Margin="15,0">
                        <TextBlock Text="Главная" Foreground="#444" VerticalAlignment="Center" FontSize="14"/>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#888" FontSize="12">
                            <Run Text="ООО Торговые Автоматы"/>
                            <Run Text=" | "/>
                            <Run Text="Главная"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Личный кабинет. Главная" 
                                   FontSize="24" Margin="0,0,0,20" FontWeight="Light" Foreground="#333"/>

                        <!-- ЛЕВАЯ КОЛОНКА: ВИДЖЕТЫ -->
                        <UniformGrid Grid.Row="1" Grid.Column="0" Columns="2" Rows="1">
                            <!-- Эффективность сети -->
                            <Border Background="White" Margin="0,0,10,15" BorderBrush="#d2d6de" BorderThickness="1" CornerRadius="2">
                                <StackPanel Margin="15">
                                    <Grid>
                                        <TextBlock Text="Эффективность сети" FontWeight="Bold"/>
                                        <TextBlock Text="85%" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#3c8dbc" FontSize="18"/>
                                    </Grid>
                                    <lvc:PieChart Height="120" Series="{Binding EfficiencySeries}" 
                                                  InitialRotation="-90" MaxAngle="180" Margin="0,5,0,0"/>
                                    <TextBlock Text="Работающих автоматов: 17 из 20" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Состояние сети -->
                            <Border Background="White" Margin="5,0,0,15" BorderBrush="#d2d6de" BorderThickness="1" CornerRadius="2">
                                <StackPanel Margin="15">
                                    <TextBlock Text="Состояние сети" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <lvc:PieChart Height="120" Series="{Binding StatusSeries}"/>
                                    <WrapPanel Margin="0,5,0,0" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Rectangle Width="10" Height="10" Fill="#00a65a" Margin="0,0,3,0"/>
                                            <TextBlock Text="Работает" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Rectangle Width="10" Height="10" Fill="#f39c12" Margin="0,0,3,0"/>
                                            <TextBlock Text="Не работает" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Rectangle Width="10" Height="10" Fill="#dd4b39" Margin="0,0,3,0"/>
                                            <TextBlock Text="Обслуживание" FontSize="11"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- ПРАВАЯ КОЛОНКА: СВОДКА И НОВОСТИ -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Margin="15,0,0,0">
                            <Border Background="White" Margin="0,0,0,15" BorderBrush="#d2d6de" BorderThickness="1" CornerRadius="2">
                                <StackPanel Margin="15">
                                    <TextBlock Text="Сводка" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <Grid Margin="0,5">
                                        <TextBlock Text="Продажи сегодня" Foreground="#666"/>
                                        <TextBlock Text="47 250 ₽" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#00a65a"/>
                                    </Grid>
                                    <Separator Background="#eee" Margin="0,5"/>
                                    <Grid Margin="0,5">
                                        <TextBlock Text="Инкассация (план)" Foreground="#666"/>
                                        <TextBlock Text="32 000 ₽" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                    <Separator Background="#eee" Margin="0,5"/>
                                    <Grid Margin="0,5">
                                        <TextBlock Text="Обслуживание ТА" Foreground="#666"/>
                                        <TextBlock Text="3 автомата" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#f39c12"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#d2d6de" BorderThickness="1" CornerRadius="2">
                                <StackPanel Margin="15">
                                    <TextBlock Text="Новости франчайзера" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <ItemsControl>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#eee" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="Обновление прошивки автоматов" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <TextBlock Text="12.04.2026" FontSize="11" Foreground="#888" Margin="0,3,0,0"/>
                                                        <TextBlock Text="Доступно новое ПО для моделей Unicum и Saeco..." 
                                                                   TextWrapping="Wrap" FontSize="12" Foreground="#555" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Items>
                                            <system:String>news1</system:String>
                                            <system:String>news2</system:String>
                                            <system:String>news3</system:String>
                                        </ItemsControl.Items>
                                    </ItemsControl>
                                    <Button Content="Все новости" Style="{StaticResource MaterialDesignFlatButton}" 
                                            HorizontalAlignment="Right" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ГРАФИК ПРОДАЖ -->
                        <Border Grid.Row="2" Grid.Column="0" Background="White" BorderBrush="#d2d6de" BorderThickness="1" CornerRadius="2">
                            <StackPanel Margin="15">
                                <Grid>
                                    <TextBlock Text="Динамика продаж за последние 10 дней" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <RadioButton Content="Сумма" IsChecked="True" Margin="0,0,10,0" GroupName="SalesFilter"/>
                                        <RadioButton Content="Количество" GroupName="SalesFilter"/>
                                    </StackPanel>
                                </Grid>
                                <lvc:CartesianChart Height="250" Series="{Binding SalesSeries}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>